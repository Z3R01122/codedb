    "title": "throttle function js",
    "tags": ["js","utils","performance"],
    "code": "function throttle(fn, ms) {\n    let last = 0;\n    return (...a) => {\n        const now = Date.now();\n        if (now - last > ms) {\n            last = now;\n            fn(...a);\n        }\n    };\n}"
